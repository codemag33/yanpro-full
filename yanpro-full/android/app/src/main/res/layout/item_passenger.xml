<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/uber_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Header: name + status dot -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/passengerDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_online_dot" />

            <TextView
                android:id="@+id/tvPassengerName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="@color/uber_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvPassengerStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/passenger_waiting"
                android:textColor="@color/uber_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Addresses -->
        <TextView
            android:id="@+id/tvPickupAddr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:drawableStart="@drawable/ic_point_a"
            android:drawablePadding="8dp"
            android:textColor="@color/uber_text_secondary"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvDestAddr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:drawableStart="@drawable/ic_dest_pin"
            android:drawablePadding="8dp"
            android:textColor="@color/uber_text_secondary"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Slide to accept -->
        <com.driver.app.widget.SlideToAcceptView
            android:id="@+id/sliderPassengerAccept"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:visibility="visible" />

        <!-- Chat button (when active) -->
        <Button
            android:id="@+id/btnPassengerChat"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="end"
            android:visibility="gone"
            android:text="@string/chat_short"
            android:textColor="@color/uber_blue"
            android:textSize="12sp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
