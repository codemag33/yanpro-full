<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/uber_black"
    android:orientation="vertical"
    tools:context=".HistoryActivity">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/uber_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/history_back"
            android:src="@drawable/ic_close"
            android:scaleType="centerInside"
            android:padding="12dp"
            app:tint="@color/uber_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/history_title"
            android:textColor="@color/uber_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHistoryCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/uber_text_secondary"
            android:textSize="13sp"
            tools:text="12 заказов" />
    </LinearLayout>

    <!-- Filter chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/uber_dark"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAll"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/history_filter_all"
            android:textColor="@color/uber_text_primary"
            android:textSize="12sp"
            app:chipBackgroundColor="@color/uber_card"
            app:chipStrokeWidth="0dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipRides"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/history_filter_rides"
            android:textColor="@color/uber_text_primary"
            android:textSize="12sp"
            app:chipBackgroundColor="@color/uber_card"
            app:chipStrokeWidth="0dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAssists"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/history_filter_assists"
            android:textColor="@color/uber_text_primary"
            android:textSize="12sp"
            app:chipBackgroundColor="@color/uber_card"
            app:chipStrokeWidth="0dp" />
    </LinearLayout>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_history"
            android:alpha="0.3"
            android:contentDescription="@null"
            app:tint="@color/uber_text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/history_empty"
            android:textColor="@color/uber_text_secondary"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Loading -->
    <LinearLayout
        android:id="@+id/loadingState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/uber_green" />
    </LinearLayout>

    <!-- History list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        tools:listitem="@layout/item_history" />

</LinearLayout>
