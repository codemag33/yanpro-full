<?xml version="1.0" encoding="utf-8"?>
<!-- Uber-style ride request bottom sheet -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingTop="12dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_drag_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header: "Новый заказ" + countdown -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/ride_request_title"
                android:textColor="@color/uber_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRideCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_countdown"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textColor="@color/uber_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="0:15" />
        </LinearLayout>

        <!-- Passenger info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Avatar placeholder -->
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_avatar"
                android:contentDescription="@null"
                android:padding="10dp"
                android:src="@drawable/ic_person"
                android:scaleType="centerInside" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPassengerName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/uber_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Иван" />

                <TextView
                    android:id="@+id/tvPassengerRating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/ride_passenger_rating"
                    android:textColor="@color/uber_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Route info: Pickup → Destination -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <!-- Timeline dots -->
            <LinearLayout
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_dot_pickup" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"
                    android:background="@color/uber_text_secondary" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/bg_dot_dest" />
            </LinearLayout>

            <!-- Addresses -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPickupAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/uber_text_primary"
                    android:textSize="15sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    tools:text="ул. Тверская, 1" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/uber_divider" />

                <TextView
                    android:id="@+id/tvDestAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/uber_text_primary"
                    android:textSize="15sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    tools:text="ул. Арбат, 10" />
            </LinearLayout>
        </LinearLayout>

        <!-- Earnings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_earnings"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/ride_earnings_label"
                android:textColor="@color/uber_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvEarnings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="450 ₽"
                android:textColor="@color/uber_green"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Accept / Decline buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDeclineRide"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/ride_decline"
                android:textColor="@color/uber_red"
                android:textSize="15sp"
                app:strokeColor="@color/uber_red"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <Button
                android:id="@+id/btnAcceptRide"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:backgroundTint="@color/uber_green"
                android:text="@string/ride_accept"
                android:textColor="@color/uber_black"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
