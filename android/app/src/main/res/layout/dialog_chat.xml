<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingTop="12dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_drag_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chat_title"
            android:textColor="@color/uber_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="@color/uber_divider" />

        <ScrollView
            android:id="@+id/scrollChat"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:background="@drawable/bg_chat_bubble_area"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvChatLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/uber_text_primary"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etChatInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_uber_search_bar"
                android:hint="@string/chat_input_hint"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/uber_text_primary"
                android:textColorHint="@color/uber_text_hint"
                android:textSize="14sp"
                android:importantForAutofill="no" />

            <ImageButton
                android:id="@+id/btnSendChat"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_send_button"
                android:contentDescription="@string/chat_send"
                android:src="@drawable/ic_send"
                android:scaleType="centerInside"
                app:tint="@color/uber_black" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
